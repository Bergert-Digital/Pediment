{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "pediment/feature",
	"title": "Feature",
	"category": "pediment",
	"description": "A single icon + title + text + optional link card. Allowed icons: arrow-right, article, bank, caret-down, check-circle, gear, microphone, monitor-play, seal-check, stack, trend-up.",
	"parent": [ "pediment/feature-grid" ],
	"textdomain": "pediment",
	"supports": { "html": false, "inserter": false },
	"attributes": {
		"icon": {
			"type": "string",
			"default": "trend-up",
			"enum": [
				"arrow-right",
				"article",
				"bank",
				"caret-down",
				"check-circle",
				"gear",
				"microphone",
				"monitor-play",
				"seal-check",
				"stack",
				"trend-up"
			]
		},
		"title": { "type": "string", "default": "" },
		"text": { "type": "string", "default": "" },
		"linkText": { "type": "string", "default": "" },
		"linkUrl": { "type": "string", "default": "" }
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
